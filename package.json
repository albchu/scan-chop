{
  "name": "scan-chop",
  "version": "1.0.0",
  "description": "A desktop application for automatically detecting and extracting individual images from scanned documents containing multiple photos or images",
  "keywords": [
    "image-processing",
    "electron",
    "typescript",
    "computer-vision",
    "photo-scanning",
    "image-splitting"
  ],
  "author": "Albert Chu <albertchu539@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/albchu/scan-chop.git"
  },
  "packageManager": "pnpm@9.14.2",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:prod": "turbo run build:prod",
    "build:electron": "turbo run build:prod --filter=electron-app",
    "package:electron": "turbo run package --filter=electron-app",
    "release:electron": "turbo run release --filter=electron-app",
    "dev": "turbo run build --filter=electron-app && turbo run dev --filter=electron-app",
    "dev:debug": "DEBUG=true turbo run build --filter=electron-app && DEBUG=true turbo run dev --filter=electron-app",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf .turbo/cache",
    "find-unused": "knip"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "typescript-eslint": "^8.57.0",
    "knip": "^5.86.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=8.0.0"
  }
}
