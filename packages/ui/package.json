{
  "name": "@workspace/ui",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "style": "dist/styles/index.css",
  "scripts": {
    "build": "pnpm build:js && pnpm build:css && pnpm build:modules",
    "build:js": "tsc",
    "build:css": "pnpm dlx @tailwindcss/cli -i ./src/styles/index.css -o ./dist/styles/index.css",
    "build:modules": "find src -name '*.module.css' -exec sh -c 'mkdir -p dist/$(dirname {} | cut -d/ -f2-) && cp {} dist/$(dirname {} | cut -d/ -f2-)/' \\;",
    "dev:css": "pnpm dlx @tailwindcss/cli -i ./src/styles/index.css -o ./dist/styles/index.css --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.40.0",
    "@workspace/shared": "workspace:*",
    "immer": "^10.0.3",
    "lodash": "^4.17.23",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-moveable": "^0.56.0",
    "sonner": "^1.7.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.0.0",
    "@types/lodash": "^4.17.24",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.0.3",
    "eslint-plugin-vitest-globals": "^1.6.1",
    "jsdom": "^23.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
